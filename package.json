{
  "name": "plaud-mcp",
  "version": "1.0.3",
  "description": "MCP server for Plaud.ai — access audio recordings, transcripts, and summaries",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "plaud-mcp": "src/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "plaud",
    "transcription",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charathram/plaud-mcp.git"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "login": "bun run src/login.ts",
    "start": "bun run src/index.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "dump-api": "bun scripts/dump-api.ts",
    "build": "bash build.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "puppeteer-core": "^24.40.0"
  }
}